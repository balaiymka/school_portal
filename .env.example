# Example environment variables for Postgres connection
# Copy this to .env and fill values (or set environment variables directly).

# Postgres host (default: localhost)
PGHOST=localhost
# Postgres port (default: 5432)
# Postgres port (default: 5433 for docker-compose mapping)
# If you use the provided docker-compose.yml it maps host port 5433 -> container 5432.
PGPORT=5433
# Postgres user
PGUSER=postgres
# Postgres password
PGPASSWORD=1234
# Database name
PGDATABASE=school_portal

# Optional: set PORT the server listens on
PORT=5001
